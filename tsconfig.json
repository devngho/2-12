{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "esnext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "esModuleInterop": true
  },
  "include": [
    "*.js",
    "**/*.js",
    "*.d.ts",
    "**/*.d.ts"
  ]
}
